# UPDATE .env.example AND CODESPACES SECRETS WHEN CHANGING .env KEYS
# https://github.com/Tasktix/Tasktix/settings/secrets/codespaces
# ##########################################################

DB_DATABASE=tasktix
DB_PASSWORD=password

BETTER_AUTH_SECRET=generate a random secret value, 32 char min
BETTER_AUTH_URL=http://localhost:3000 # Base URL of APP
ENABLE_PASSWORD_STRENGTH_CHECK=true

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

OAUTH_PROVIDER_ID= # Represents provider name in the GUI, so style appropriately (i.e. Title Case)
OAUTH_SCOPES= # Optional; what scopes should be used if OIDC provider requires
OAUTH_CLIENT_ID= # Client ID generated by OIDC provider
OAUTH_CLIENT_SECRET= # Client secret generated by ODIC provider
OAUTH_AUTHORIZATION_URL= # Can be inferred if OAUTH_DISCOVERY_URL is set; otherwise, the URL to authorize at
OAUTH_DISCOVERY_URL= # Optional; URL to the OIDC provider's `.well-known/openid-configuration` endpoint for quick configuration

# ##########################################################
# UPDATE .env.example AND CODESPACES SECRETS WHEN CHANGING .env KEYS
